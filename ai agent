import React, { useState, useEffect, useRef } from 'react';
import { LucideImage, LucideSend, LucidePaperclip, LucideX, LucideCheckCircle, LucidePackage, LucideWand2, LucideLayout, LucideShoppingCart, LucideSearch, LucideSparkles } from 'lucide-react';

const apiKey = ""; // Provided at runtime

// Симулированная база данных 1С для контекста
const MOCK_1C_DB = [
  { id: 1, name: "Линолеум Версаль Сахалин 3м", price: 660, unit: "м²", stock: 45, warehouse: "Склад Энгельс", img: "https://images.unsplash.com/photo-1581850518616-bcb8186c443e?auto=format&fit=crop&q=80&w=600" },
  { id: 2, name: "Ламинат Classen Дуб Светлый", price: 1250, unit: "м²", stock: 120, warehouse: "Маяковского, 157", img: "https://images.unsplash.com/photo-1516455590571-18256e5bb9ff?auto=format&fit=crop&q=80&w=600" },
  { id: 3, name: "Краска Tikkurila Euro Power 7", price: 4200, unit: "9л", stock: 15, warehouse: "Центральный Склад", img: "https://images.unsplash.com/photo-1589939705384-5185137a7f0f?auto=format&fit=crop&q=80&w=600" },
  { id: 4, name: "Плитка керамогранит Loft Grey", price: 1890, unit: "м²", stock: 88, warehouse: "Склад Энгельс", img: "https://images.unsplash.com/photo-1523413555809-0fb8a4da203d?auto=format&fit=crop&q=80&w=600" }
];

export default function App() {
  const [messages, setMessages] = useState([
    { role: 'bot', text: 'Здравствуйте! Я ваш персональный ИИ-ассистент Стройдвора. Загрузите фото вашей комнаты или опишите проект, и я подберу материалы с учетом остатков на наших складах.', type: 'text' }
  ]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [loadingPhase, setLoadingPhase] = useState('');
  const [previewImage, setPreviewImage] = useState(null);
  const [activeVisual, setActiveVisual] = useState(null);
  const [activeProduct, setActiveProduct] = useState(null);
  
  const chatEndRef = useRef(null);
  const scrollToBottom = () => chatEndRef.current?.scrollIntoView({ behavior: "smooth" });
  useEffect(scrollToBottom, [messages, loading]);

  const callGemini = async (prompt, imageData = null) => {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
    const contents = [{
      parts: [
        { text: prompt },
        ...(imageData ? [{ inlineData: { mimeType: "image/png", data: imageData.split(',')[1] } }] : [])
      ]
    }];
    const systemInstruction = {
      parts: [{ text: "Ты — экспертный ИИ-консультант сайта stroydvor2002.ru. Помогай подбирать стройматериалы. Если прислали фото — анализируй его стиль и нужды. Предлагай конкретные товары. Отвечай вежливо на русском." }]
    };

    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ contents, systemInstruction })
    });
    const data = await response.json();
    return data.candidates?.[0]?.content?.parts?.[0]?.text;
  };

  const generateVisualization = async (prompt) => {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`;
    const payload = {
      instances: [{ prompt: `Photorealistic interior design visualization: ${prompt}, hyper-realistic, 8k, modern home style` }],
      parameters: { sampleCount: 1 }
    };
    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await response.json();
    return `data:image/png;base64,${data.predictions[0].bytesBase64Encoded}`;
  };

  const handleSend = async (textOverride = null, imgOverride = null) => {
    const text = textOverride || input;
    const img = imgOverride || previewImage;
    if (!text && !img) return;

    setMessages(prev => [...prev, { role: 'user', text: text || "Анализ фото", image: img }]);
    setInput('');
    setPreviewImage(null);
    setLoading(true);

    try {
      setLoadingPhase("Анализирую проект...");
      if (text.toLowerCase().includes("визуализируй") || text.toLowerCase().includes("покажи")) {
        setLoadingPhase("Генерирую дизайн-концепт...");
        const visual = await generateVisualization(text);
        if (visual) setActiveVisual(visual);
      }

      const response = await callGemini(text, img);
      setMessages(prev => [...prev, { role: 'bot', text: response }]);

      const lowerResp = response.toLowerCase();
      const product = MOCK_1C_DB.find(p => lowerResp.includes(p.name.split(' ')[0].toLowerCase()) || lowerResp.includes(p.name.toLowerCase().split(' ')[0]));
      if (product) setActiveProduct(product);

    } catch (err) {
      setMessages(prev => [...prev, { role: 'bot', text: "Произошла техническая заминка. Пожалуйста, попробуйте еще раз." }]);
    } finally {
      setLoading(false);
      setLoadingPhase("");
    }
  };

  return (
    <div className="w-full min-h-[700px] bg-slate-100 flex items-center justify-center p-6 font-sans">
      <div className="w-full max-w-7xl h-[650px] bg-white rounded-[40px] shadow-2xl overflow-hidden flex flex-row border border-slate-200">
        
        {/* Панель ЧАТА (Левая) */}
        <div className="w-[400px] border-r border-slate-100 flex flex-col bg-white">
          <div className="p-6 border-b border-slate-50 flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className="w-12 h-12 bg-[#00569c] rounded-2xl flex items-center justify-center text-white font-bold shadow-lg shadow-blue-100">СД</div>
              <div>
                <h3 className="font-bold text-slate-800">ИИ-Помощник</h3>
                <p className="text-[10px] text-green-500 font-bold uppercase tracking-wider flex items-center gap-1">
                  <span className="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span> Онлайн
                </p>
              </div>
            </div>
            <LucideSparkles className="text-[#f39200]" size={20} />
          </div>

          <div className="flex-1 overflow-y-auto p-4 space-y-4 bg-[#f8fafc]/50 scrollbar-hide">
            {messages.map((msg, i) => (
              <div key={i} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}>
                <div className={`max-w-[85%] p-4 text-sm leading-relaxed shadow-sm ${
                  msg.role === 'user' 
                    ? 'bg-[#00569c] text-white rounded-2xl rounded-tr-none' 
                    : 'bg-white text-slate-700 rounded-2xl rounded-tl-none border border-slate-100'
                }`}>
                  {msg.image && <img src={msg.image} className="rounded-lg mb-2 max-h-32 w-full object-cover" />}
                  {msg.text}
                </div>
              </div>
            ))}
            {loading && (
              <div className="flex items-center gap-2 p-2">
                <div className="flex space-x-1">
                  <div className="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce" style={{animationDelay: '0s'}}></div>
                  <div className="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce" style={{animationDelay: '0.2s'}}></div>
                  <div className="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce" style={{animationDelay: '0.4s'}}></div>
                </div>
                <span className="text-[10px] font-bold text-blue-600 uppercase tracking-tighter">{loadingPhase}</span>
              </div>
            )}
            <div ref={chatEndRef} />
          </div>

          <div className="p-4 bg-white border-t border-slate-50">
            {previewImage && (
              <div className="mb-2 relative inline-block">
                <img src={previewImage} className="w-16 h-16 rounded-xl object-cover border-2 border-[#f39200]" />
                <button onClick={() => setPreviewImage(null)} className="absolute -top-2 -right-2 bg-red-500 text-white rounded-full p-1"><LucideX size={10}/></button>
              </div>
            )}
            <div className="flex items-center gap-2">
              <label className="p-3 text-slate-400 hover:text-[#00569c] cursor-pointer transition-colors">
                <LucidePaperclip size={20} />
                <input type="file" className="hidden" accept="image/*" onChange={(e) => {
                  const file = e.target.files[0];
                  if(file) {
                    const r = new FileReader();
                    r.onload = (ev) => setPreviewImage(ev.target.result);
                    r.readAsDataURL(file);
                  }
                }} />
              </label>
              <input 
                value={input}
                onChange={(e) => setInput(e.target.value)}
                onKeyDown={(e) => e.key === 'Enter' && handleSend()}
                placeholder="Задайте вопрос по ремонту..."
                className="flex-1 bg-slate-50 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-100 outline-none"
              />
              <button onClick={() => handleSend()} className="bg-[#00569c] text-white p-3 rounded-xl hover:bg-[#00427a] transition-all shadow-lg shadow-blue-100">
                <LucideSend size={20} />
              </button>
            </div>
          </div>
        </div>

        {/* Интерактивный ХОЛСТ (Центральный/Правый) */}
        <div className="flex-1 bg-[#f1f5f9] relative flex flex-col p-8">
          
          <div className="flex items-center justify-between mb-6">
            <div className="flex items-center gap-4">
              <div className="bg-white p-2 rounded-xl shadow-sm text-[#00569c]"><LucideLayout size={24}/></div>
              <h2 className="text-xl font-bold text-slate-800">Центр Подбора материалов</h2>
            </div>
            <div className="flex gap-2">
              <div className="bg-white px-4 py-2 rounded-full text-[12px] font-bold shadow-sm border border-slate-200">База 1С: Актуальна</div>
            </div>
          </div>

          <div className="flex-1 grid grid-cols-12 gap-6 overflow-hidden">
            {/* Основная область визуализации */}
            <div className="col-span-8 bg-white rounded-[32px] shadow-sm overflow-hidden flex flex-col relative border border-white">
              {activeVisual ? (
                <div className="h-full w-full relative group">
                  <img src={activeVisual} className="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Design" />
                  <div className="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-6 text-white">
                    <p className="text-sm font-medium flex items-center gap-2"><LucideWand2 size={16}/> Концепция создана ИИ специально для вас</p>
                  </div>
                  <button 
                    onClick={() => setActiveVisual(null)}
                    className="absolute top-4 right-4 bg-white/20 backdrop-blur-md text-white p-2 rounded-full hover:bg-white/40 transition-colors"
                  >
                    <LucideX size={18}/>
                  </button>
                </div>
              ) : (
                <div className="h-full flex flex-col items-center justify-center text-slate-300 p-12 text-center space-y-4">
                  <div className="w-24 h-24 rounded-full bg-slate-50 flex items-center justify-center border-2 border-dashed border-slate-200">
                    <LucideImage size={40} />
                  </div>
                  <div>
                    <h4 className="text-slate-500 font-bold">Здесь будет ваш дизайн-проект</h4>
                    <p className="text-sm max-w-[280px] mx-auto">Загрузите фото комнаты или попросите: "Покажи как будет выглядеть светлый ламинат в гостиной"</p>
                  </div>
                </div>
              )}
            </div>

            {/* Карточка товара */}
            <div className="col-span-4 flex flex-col space-y-4 h-full overflow-y-auto pr-2 scrollbar-hide">
              {activeProduct ? (
                <div className="bg-white rounded-[32px] p-6 shadow-sm border border-slate-100 flex flex-col animate-in slide-in-from-right-10 duration-500 h-full">
                  <h3 className="text-[12px] font-black uppercase text-[#f39200] mb-2 tracking-widest">Рекомендуемый товар</h3>
                  <img src={activeProduct.img} className="w-full h-44 object-cover rounded-2xl mb-4" />
                  <h4 className="font-bold text-slate-800 text-lg mb-1">{activeProduct.name}</h4>
                  <div className="text-2xl font-black text-[#00569c] mb-4">
                    {activeProduct.price} ₽ <span className="text-xs font-normal text-slate-400 italic">/{activeProduct.unit}</span>
                  </div>
                  
                  <div className="space-y-3 mb-6">
                    <div className="flex items-center gap-2 text-xs font-bold text-green-600 bg-green-50 p-2.5 rounded-xl border border-green-100">
                      <LucideCheckCircle size={16} /> В наличии: {activeProduct.stock} {activeProduct.unit}
                    </div>
                    <div className="flex items-center gap-2 text-xs font-medium text-slate-500 p-2.5 rounded-xl bg-slate-50">
                      <LucidePackage size={16} /> {activeProduct.warehouse}
                    </div>
                  </div>

                  <div className="mt-auto flex flex-col gap-3">
                    <button className="w-full bg-[#f39200] text-white py-4 rounded-2xl font-black shadow-lg shadow-orange-100 hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-2">
                      <LucideShoppingCart size={20}/> В КОРЗИНУ
                    </button>
                    <button className="w-full text-slate-400 py-2 text-xs font-bold hover:text-slate-600 transition-colors">Смотреть аналоги</button>
                  </div>
                </div>
              ) : (
                <div className="bg-slate-50/50 border-2 border-dashed border-slate-200 rounded-[32px] p-6 flex flex-col items-center justify-center text-center text-slate-400 h-full">
                   <LucideSearch size={32} className="mb-4 opacity-50" />
                   <p className="text-xs font-bold leading-tight">Подбирайте материалы в чате, и здесь появятся лучшие предложения из 1С</p>
                </div>
              )}
            </div>
          </div>

          {/* Быстрые действия */}
          <div className="absolute bottom-6 left-8 right-8 flex gap-3">
            {[
              { label: "Полы для кухни", icon: "🍳" },
              { label: "Тренды 2024", icon: "✨" },
              { label: "Рассчитать обои", icon: "📐" },
              { label: "Вызвать замерщика", icon: "🏠" }
            ].map((btn, idx) => (
              <button 
                key={idx}
                onClick={() => handleSend(btn.label)}
                className="bg-white/80 backdrop-blur px-5 py-2.5 rounded-2xl text-[12px] font-bold text-slate-600 shadow-sm hover:bg-white hover:text-[#00569c] transition-all border border-slate-100 flex items-center gap-2"
              >
                <span>{btn.icon}</span> {btn.label}
              </button>
            ))}
          </div>

        </div>
      </div>
    </div>
  );
}
